{
  "name": "@solcreek/adapter-creek",
  "version": "0.1.1",
  "description": "Next.js deployment adapter for Creek (Cloudflare Workers)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cache-handler": {
      "default": "./dist/cache-handler.js"
    }
  },
  "files": [
    "dist",
    "src/shims",
    "!dist/**/*.test.*",
    "!dist/**/*.map"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "creek",
    "nextjs",
    "adapter",
    "cloudflare",
    "workers",
    "deployment"
  ],
  "author": "SolCreek",
  "license": "Apache-2.0",
  "homepage": "https://creek.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/solcreek/adapter-creek.git"
  },
  "dependencies": {
    "@next/routing": "16.2.3",
    "@node-rs/xxhash": "^1.7.6",
    "sql.js": "^1.14.1",
    "wrangler": "^4.82.2"
  },
  "peerDependencies": {
    "next": ">=16.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "miniflare": "^4.20260410.0",
    "next": "16.2.3",
    "typescript": "^5.8.2",
    "urlpattern-polyfill": "^10.1.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0"
}
